.ipynb_checkpoints/
__pycache__
# Python virtual environments
.venv/
.venv
.venv*
.venv_fuest/
venv/
venv*
env/
*.err
*.log

# Python package build artifacts
*.egg-info/
dist/
build/
*.egg

# HPC/PBS output files
*.o[0-9]*
*.e[0-9]*
*.out
# Logs folders (anywhere in repo)
logs/
logs/*/
!logs/.gitkeep
!logs/*/.gitkeep
!**/logs/.gitkeep

# PBS scripts (cluster-specific)
scripts/pbs/

# Old/deprecated code
**/old/

# Backup directories
*_backup_*
*backup*/

# Working notes and development - ignore entire notes folder
notes/

# Generated results and plots
results/
examples/*/results/
examples/*/images/
*.png
*.jpg
*.jpeg
*.pdf
*.eps
*.svg

# But allow documentation images if needed
!docs/images/*.png
!docs/images/*.jpg
!docs/images/*.svg
!docs/images/**/*.svg

# Work-in-progress files
*_wip.py
*_draft.*
*.draft

# Temporary and test files
test_*.py
verify_*.py
*_test.py
temp/
archive/

# Documentation drafts
docs/paper/
docs/*.tex
docs/*_draft.*
dynx_repo/

# MkDocs build output
site/
