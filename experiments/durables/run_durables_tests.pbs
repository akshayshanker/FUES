#!/bin/bash
#PBS -N durables-sweep
#PBS -P tp66
#PBS -q normalsr
#PBS -l ncpus=24,mem=200GB,walltime=10:00:00
#PBS -l storage=scratch/tp66+gdata/tp66
#PBS -l wd
#PBS -j oe
#PBS -r y
#PBS -o /g/data/tp66/logs/durables/
#PBS -e /g/data/tp66/logs/durables/

# ======================================================================
#  Durables Model - Grid convergence sweep
#  Runs sweep over grid sizes with optional Euler accuracy
# ======================================================================

VERSION="${VERSION:-v1}"

set -euo pipefail

# --- Path Setup ---
if [[ -n "${PBS_O_WORKDIR:-}" ]]; then
    REPO_ROOT="$(cd "$PBS_O_WORKDIR/../.." && pwd)"
else
    REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
fi

# --- Environment ---
module purge
module load python3/3.12.1

FUES_VENV="${FUES_VENV:-$HOME/venvs/fues}"
source "$FUES_VENV/bin/activate"

export PYTHONPATH="$REPO_ROOT/src:$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"
export OMP_NUM_THREADS=1
export NUMBA_NUM_THREADS=1
export NUMBA_CACHE_DIR=/scratch/tp66/$USER/numba_cache
mkdir -p "$NUMBA_CACHE_DIR"

echo "========================================================"
echo "Durables: Grid convergence sweep ($VERSION)"
echo "Job ID: ${PBS_JOBID:-local} | Node: $(hostname)"
echo "========================================================"

cd "$REPO_ROOT"

# Paper table: 4 grids × 3 tau × 2 methods = 24 points on 24 cores
module load openmpi/4.1.5

# Suppress OpenMPI basesmuma warnings
export OMPI_MCA_coll_hcoll_enable=0
export OMPI_MCA_coll=^hcoll
export PMIX_MCA_gds=hash

# make_run_dir is MPI-safe: rank 0 creates YYYY-MM-DD/NNN/, broadcasts to all
mpiexec -n $PBS_NCPUS python3 -u -m mpi4py -m examples.durables.run \
    --sweep \
    --sweep-params n_a=250,500,750,1000 tau=0.05,0.07,0.12 method=FUES,NEGM \
    --sweep-runs 3 \
    --simulate --n-sim 10000 --seed 42 \
    --calib-override t0=20 \
    --output-dir /scratch/tp66/$USER/FUES/durables

echo "Job completed at $(date)"
