#!/bin/bash
#PBS -P tp66
#PBS -q gpuhopper
#PBS -l walltime=00:05:00
#PBS -l ncpus=12
#PBS -l ngpus=1
#PBS -l mem=64GB
#PBS -l jobfs=100MB
#PBS -l storage=scratch/tp66+gdata/tp66
#PBS -l wd
#PBS -N cuda_test
#PBS -j oe

# Minimal CUDA test to diagnose cuMemGetMemPool segfault

REPO_ROOT="$HOME/dev/fues.dev/FUES"
cd "$REPO_ROOT"

# Load modules
module purge
module load python3/3.12.1 
module load cuda/12.9.0

# Activate venv (stored in scratch)
VENV_PUBLIC="${VENV_PUBLIC:-/scratch/tp66/$USER/venvs/fues_public}"
source "$VENV_PUBLIC/bin/activate"

# Show GPU info
echo "=== GPU Information ==="
nvidia-smi --query-gpu=index,name,memory.total,driver_version --format=csv
nvcc --version | tail -1
echo ""

# Show package versions
echo "=== Package Versions ==="
python3 -c "import numba; print(f'Numba: {numba.__version__}')"
pip show numba-cuda 2>/dev/null | grep -E "^(Name|Version)" || echo "numba-cuda: NOT INSTALLED"
echo ""

# Test 1: Baseline (no workarounds)
echo "=== TEST 1: Baseline ==="
python3 experiments/housing_renting/cuda_test.py 2>&1 || echo "TEST 1 FAILED"
echo ""

# Test 2: With NUMBA_CUDA_USE_NVIDIA_BINDING=1
echo "=== TEST 2: NUMBA_CUDA_USE_NVIDIA_BINDING=1 ==="
export NUMBA_CUDA_USE_NVIDIA_BINDING=1
python3 experiments/housing_renting/cuda_test.py 2>&1 || echo "TEST 2 FAILED"
unset NUMBA_CUDA_USE_NVIDIA_BINDING
echo ""

# Test 3: Check numba-cuda import
echo "=== TEST 3: Check numba_cuda module ==="
python3 -c "import numba_cuda; print('numba_cuda imported successfully')" 2>&1 || echo "numba_cuda not available"
python3 experiments/housing_renting/cuda_test.py 2>&1 || echo "TEST 3 FAILED"
echo ""

# Test 4: CUDA Simulator (control - always works)
echo "=== TEST 4: CUDA Simulator (control) ==="
export NUMBA_ENABLE_CUDASIM=1
python3 experiments/housing_renting/cuda_test.py 2>&1 || echo "TEST 4 FAILED"
unset NUMBA_ENABLE_CUDASIM

echo ""
echo "=== All tests complete ==="
